class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        unordered_map<int,int>freq;
     
        for(int num:nums){
            freq[num]++;
        }

vector<int>unique;

        for(auto &it :freq){

            unique.push_back(it.first);

        }
        sort(unique.begin(),unique.end());
        for(int i =unique.size()-1;i>=0;i--){
            k-=freq[unique[i]];
            if(k<=0){
                return unique[i];
            }

        }

return -1;
       


        
    }
};
