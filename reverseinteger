class Solution {
public:
    int reverse(int x) {
        int digit=0;
        while(x!=0){
            int rem=x%10;
            if (digit > INT_MAX / 10 || digit < INT_MIN / 10) {
                return 0;//donee to prevent overflow as the limit is already given in the question 

            }
            digit=digit*10+rem;
            x=x/10;
        }
        return digit;
        
    }
};
