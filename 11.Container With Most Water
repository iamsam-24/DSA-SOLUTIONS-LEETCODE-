class Solution {
public:
    int maxArea(vector<int>& height) {
       int maxi=0;//taking max to store the area
        int i =0;
        int j =height.size()-1;
        while(i<=j){
//take the min height amongst the max ones to avoid spillage(the man point of the question)
           int mheight= min(height[i],height[j]); 
            int width=j-i;
//always the height and width array same 
            maxi=max(width*mheight,maxi);
            ///stored the answer in maxi 
if(height[i]<height[j]){//if found lower lett the i iterate futher
    i++;
}
else{
    j--;//otherwise j backward
}

        }
        return maxi;//returns the maxarea

        
    }
};
